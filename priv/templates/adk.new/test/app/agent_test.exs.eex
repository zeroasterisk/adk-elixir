defmodule <%= @module_name %>.AgentTest do
  use ExUnit.Case, async: true

  test "agent builds successfully" do
    agent = <%= @module_name %>.Agent.build()
    assert agent.name == "<%= @app_name %>"
    assert length(agent.tools) == 2
  end

  test "greeting tool works" do
    tool = <%= @module_name %>.Tools.greeting_tool()
    assert {:ok, result} = ADK.Tool.FunctionTool.run(tool, %{}, %{"name" => "Blackbeard"})
    assert result =~ "Blackbeard"
    assert result =~ "Ahoy"
  end

  test "calculator tool works" do
    tool = <%= @module_name %>.Tools.calculator_tool()
    assert {:ok, result} = ADK.Tool.FunctionTool.run(tool, %{}, %{"expression" => "2 + 3"})
    assert result =~ "5"
  end

  test "calculator handles invalid expression" do
    tool = <%= @module_name %>.Tools.calculator_tool()
    assert {:ok, result} = ADK.Tool.FunctionTool.run(tool, %{}, %{"expression" => "foo"})
    assert result =~ "can't make sense"
  end
end
